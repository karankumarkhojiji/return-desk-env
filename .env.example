# ============================================================
# ReturnDeskEnv — Environment Variable Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file to a new file named exactly: .env
#      (no extension, just .env)
#   2. Fill in YOUR real values in the .env file
#   3. NEVER commit the .env file to GitHub (it's in .gitignore)
#   4. This .env.example file IS safe to commit — it has no real secrets
# ============================================================

# ---- LLM Provider Settings (Hugging Face Router) -----------
# Your Hugging Face Access Token
# Get it from: https://huggingface.co/settings/tokens
# Required for LLM mode. Not needed for deterministic mode.
HF_TOKEN=hf_your_token_here

# The API base URL (HuggingFace Router is free and works well)
API_BASE_URL=https://router.huggingface.co/v1

# The model to use. Qwen2.5-72B is a strong free model on HF Router.
# Other options: meta-llama/Llama-3.3-70B-Instruct, mistralai/Mistral-7B-Instruct-v0.3
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ---- Environment Server Settings ---------------------------
# URL of your running ReturnDeskEnv server
# Keep this as localhost when running locally
RETURN_DESK_BASE_URL=http://localhost:8000

# ---- Inference Behavior ------------------------------------
# Set to false to skip the LLM and use the built-in perfect policy
# Useful for testing the logging format without an API key
RETURN_DESK_USE_LLM=true

# Max steps per episode (20 is enough for all tasks)
RETURN_DESK_MAX_STEPS=20

# Which tasks to run (comma-separated, no spaces)
# RETURN_DESK_TASKS=easy_refund,medium_exchange,hard_partial_resolution
